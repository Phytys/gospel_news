# =============================================================================
# Template-based .gitignore — update from:
#   Python: https://github.com/github/gitignore/blob/main/Python.gitignore
#   Docker: add docker-compose overrides, .env (secrets)
# =============================================================================

# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class

# C extensions
*.so

# Distribution / packaging
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
# Only ignore a root-level `lib/` (Python packaging). Do not use bare `lib/` — it hides `apps/web/src/lib/`.
/lib/
lib64/
parts/
sdist/
var/
wheels/
share/python-wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST

# PyInstaller
*.manifest
*.spec

# Installer logs
pip-log.txt
pip-delete-this-directory.txt

# Unit test / coverage reports
htmlcov/
.tox/
.nox/
.coverage
.coverage.*
.cache
nosetests.xml
coverage.xml
*.cover
*.py.cover
.hypothesis/
.pytest_cache/
cover/

# Translations
*.mo
*.pot

# Django stuff
*.log
local_settings.py
db.sqlite3
db.sqlite3-journal

# Flask stuff
instance/
.webassets-cache

# Jupyter Notebook
.ipynb_checkpoints

# pyenv
# .python-version

# Environments
.env
.envrc
.env.*
!.env.example
.venv
venv/
env/
ENV/
env.bak/
venv.bak/

# mypy
.mypy_cache/
.dmypy.json
dmypy.json

# Pyre type checker
.pyre/

# pytype static type analyzer
.pytype/

# Ruff
.ruff_cache/

# Windows metadata (WSL / downloaded files)
*.Zone.Identifier
**/*Zone.Identifier

# =============================================================================
# Docker
# =============================================================================
docker-compose.override.yml
docker-compose.override.yaml
.docker/
