# Gospel Resonance — copy to .env

OPENROUTER_API_KEY=replace_me
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_SITE_URL=https://yourdomain.example
OPENROUTER_APP_TITLE=Gospel Resonance
OPENROUTER_CHAT_MODEL=x-ai/grok-4.1-fast
OPENROUTER_EMBED_MODEL=openai/text-embedding-3-large
OPENROUTER_EMBED_DIMENSIONS=1536

APP_ENV=dev
ADMIN_TOKEN=replace_me_long_random
EMBEDDING_VERSION=v1
PROMPT_VERSION=v1

# Must match: user / db name / password here = same as in DATABASE_URL (Compose uses these to init Postgres).
DATABASE_URL=postgresql+asyncpg://gospel:gospel@db:5432/gospel_resonance
POSTGRES_DB=gospel_resonance
POSTGRES_USER=gospel
POSTGRES_PASSWORD=replace_me_strong

# Host port mapped to Postgres (default 5433 if 5432 is already in use locally).
POSTGRES_PUBLISH_PORT=5433

# If port 8000 is busy on the host, set e.g. 8010 (must match nginx proxy_pass).
API_PUBLISH_PORT=8000

CORS_ORIGINS=http://localhost:3000
# Web client → API. Local: API on host 8000. Production same-origin behind nginx: leave empty (rebuild web after change).
NEXT_PUBLIC_API_URL=http://localhost:8000

# Worker container: cron time (UTC) for automatic daily generation (same as admin generate-daily).
DAILY_GENERATION_TIME_UTC=06:00
# Worker: run daily generation once when the worker container starts (default on; catches deploys before cron).
RUN_DAILY_ON_STARTUP=true
# API: after startup, create today’s daily if missing (default on; pairs with worker for reliability).
ENSURE_DAILY_ON_API_STARTUP=true
