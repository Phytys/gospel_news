# ===== OpenRouter =====
OPENROUTER_API_KEY=replace_me
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_SITE_URL=https://yourdomain.example
OPENROUTER_APP_TITLE=Gospel Lens MVP
OPENROUTER_CHAT_MODEL=x-ai/grok-4.1-fast
OPENROUTER_EMBED_MODEL=openai/text-embedding-3-large
OPENROUTER_EMBED_DIMENSIONS=1536

# ===== App =====
APP_ENV=prod
APP_BASE_URL=http://localhost:8000
ADMIN_TOKEN=replace_me_long_random

# Daily digest generation time (Singapore time, 24h HH:MM)
DIGEST_TIME_SGT=06:30
STORIES_PER_DAY=3

# RSS sources file inside container
RSS_SOURCES_FILE=/app/config/rss_sources.json

# Retrieval
CANONICAL_TOP_K=20
THOMAS_TOP_K=10

# ===== Postgres =====
POSTGRES_DB=gospellens
POSTGRES_USER=gospellens
POSTGRES_PASSWORD=replace_me_strong
DATABASE_URL=postgresql+asyncpg://gospellens:replace_me_strong@db:5432/gospellens

# ===== Optional =====
# If true, the worker will try to run a digest immediately at startup (useful for first deploy)
RUN_DIGEST_ON_STARTUP=false
